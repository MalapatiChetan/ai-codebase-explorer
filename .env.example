# ============================================================================
# AI CODEBASE EXPLAINER - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Note: Boolean values must be lowercase: true, false (or 1, 0)
# ============================================================================

# ---- Google Gemini API Configuration (REQUIRED)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Valid Gemini models (as of March 2026):
#   - gemini-2.5-flash       ← Recommended: Fast, intelligent
#   - gemini-2.5-pro         ← Advanced reasoning (slower)
#   - gemini-2.0-flash       ← Stable, well-tested
#   - gemini-flash-latest    ← Always use latest flash version
# IMPORTANT: gemini-1.5-flash is DEPRECATED - use 2.5 or later
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_TEMPERATURE=0.7
GOOGLE_MAX_TOKENS=4000

# ---- AI Chat Control
# Set to 'false' to disable AI and use rule-based answers only
ENABLE_AI_CHAT=true

# ---- Repository Analysis
REPO_CLONE_PATH=./data/repos
MAX_REPO_SIZE_MB=500
MAX_ANALYSIS_FILES=100

# ---- GitHub API (Optional - for private repositories)
GITHUB_TOKEN=
GITHUB_USERNAME=

# ---- Diagram Generation
DIAGRAM_OUTPUT_PATH=./data/diagrams
GENERATE_MERMAID=true
GENERATE_GRAPHVIZ=true

# ---- Database Caching (Optional)
DATABASE_URL=
ENABLE_CACHING=false
CACHE_TTL_HOURS=24

# ---- Async Processing (Optional)
ENABLE_ASYNC_PROCESSING=false
TASK_QUEUE_URL=

# ---- RAG (Retrieval-Augmented Generation) Configuration
# RAG allows the system to search through code for context-aware answers
ENABLE_RAG=true
# Set to 'false' to skip indexing during analysis, index on-demand when queries need it
ENABLE_RAG_INDEX_ON_ANALYZE=false
RAG_INDEX_PATH=./data/rag_indices
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# ---- Debug Mode
# Set to 'true' for verbose logging (use: true, false, 1, 0)
DEBUG=false

# ============================================================================
# NOTES:
# - Backend uses this .env file (must be in project root)
# - Frontend uses .env.local (in frontend/ directory) - NOT this file
# - If GOOGLE_API_KEY is empty, system falls back to rule-based answers
# - Set ENABLE_AI_CHAT=false to force rule-based mode (keeps key private)
# ============================================================================
